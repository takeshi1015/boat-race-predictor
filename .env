# Project environment template values (no real secrets)
DATABASE_URL=postgresql://localhost:5432/boat_race_db
DATABASE_ECHO=False

USE_EMAIL=False
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_RECIPIENTS=

USE_LINE=False
LINE_NOTIFY_TOKEN=

REQUEST_TIMEOUT=30
SCRAPER_RETRY_COUNT=3
SCRAPER_RETRY_DELAY=5

HIGH_CONFIDENCE_RACES=5
HIGH_ODDS_RACES=5
CONFIDENCE_THRESHOLD=0.6

MODEL_SAVE_PATH=./models/
EPOCHS=50
BATCH_SIZE=32
LEARNING_RATE=0.001
NN_DROPOUT_RATE=0.3

Q_LEARNING_ALPHA=0.1
Q_LEARNING_GAMMA=0.99
Q_LEARNING_EPSILON=0.1

SCHEDULE_TODAY=06:00
SCHEDULE_TOMORROW=18:00
SCHEDULE_EVALUATE=23:30

ACCURACY_ALERT_THRESHOLD=0.40
ALERT_LOW_ACCURACY=True

LOG_LEVEL=INFO
LOG_FILE=logs/boat_race_predictor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

ENVIRONMENT=development
DEBUG=False
