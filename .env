# ==================== DATABASE ====================
DATABASE_URL=postgresql://user:password@localhost:5432/boat_race_db
DATABASE_ECHO=False

# ==================== EMAIL SETTINGS ====================
USE_EMAIL=True
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# ==================== LINE SETTINGS ====================
USE_LINE=True
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# ==================== SCRAPER SETTINGS ====================
REQUEST_TIMEOUT=30
SCRAPER_RETRY_COUNT=3
SCRAPER_RETRY_DELAY=5

# ==================== PREDICTION SETTINGS ====================
HIGH_CONFIDENCE_RACES=5
HIGH_ODDS_RACES=5
CONFIDENCE_THRESHOLD=0.6

# ==================== MACHINE LEARNING ====================
MODEL_SAVE_PATH=./models/
EPOCHS=50
BATCH_SIZE=32
LEARNING_RATE=0.001
NN_DROPOUT_RATE=0.3

# ==================== REINFORCEMENT LEARNING ====================
Q_LEARNING_ALPHA=0.1
Q_LEARNING_GAMMA=0.99
Q_LEARNING_EPSILON=0.1

# ==================== SCHEDULER SETTINGS ====================
SCHEDULE_TODAY=06:00
SCHEDULE_TOMORROW=18:00
SCHEDULE_EVALUATE=23:30

# ==================== PERFORMANCE MONITORING ====================
ACCURACY_ALERT_THRESHOLD=0.40
ALERT_LOW_ACCURACY=True

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/boat_race_predictor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==================== ENVIRONMENT ====================
ENVIRONMENT=production
DEBUG=False
